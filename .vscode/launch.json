{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug OS",
      "type": "cppdbg",
      "request": "launch",
      "MIMode": "gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "program": "${workspaceFolder}/bin/kernel",
      "cwd": "${workspaceFolder}",
      "setupCommands": [
        {
          "description": "Set architecture to i386",
          "text": "set architecture i386",
          "ignoreFailures": false
        },
                ]
    }
  ]
}
